<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           prefWidth="1200" prefHeight="800"
           fx:controller="com.autoatelier.controller.RegisterController"
           styleClass="auth-root">

    <HBox alignment="CENTER" maxWidth="900" maxHeight="640" styleClass="auth-container">

        <VBox alignment="CENTER" spacing="20" styleClass="auth-brand" minWidth="340">
            <Label text="🚗" styleClass="auth-brand-icon"/>
            <Label text="Ателье Автомобилей" styleClass="auth-brand-title"/>
            <Label text="Создайте аккаунт клиента" styleClass="auth-brand-sub"/>
        </VBox>

        <VBox alignment="CENTER" spacing="16" styleClass="auth-form" minWidth="400">
            <Label text="Регистрация" styleClass="auth-form-title"/>
            <Label text="Заполните данные для создания аккаунта" styleClass="auth-form-sub"/>

            <VBox spacing="6" maxWidth="340">
                <Label text="Имя и фамилия" styleClass="form-label-new"/>
                <TextField fx:id="nameField" promptText="Иван Иванов" styleClass="input-field"/>
            </VBox>
            <VBox spacing="6" maxWidth="340">
                <Label text="Телефон" styleClass="form-label-new"/>
                <TextField fx:id="phoneField" promptText="+7 (999) 000-00-00" styleClass="input-field"/>
            </VBox>
            <VBox spacing="6" maxWidth="340">
                <Label text="Email" styleClass="form-label-new"/>
                <TextField fx:id="emailField" promptText="your@email.com" styleClass="input-field"/>
            </VBox>
            <VBox spacing="6" maxWidth="340">
                <Label text="Пароль" styleClass="form-label-new"/>
                <PasswordField fx:id="passwordField" promptText="Минимум 6 символов" styleClass="input-field"/>
            </VBox>
            <VBox spacing="6" maxWidth="340">
                <Label text="Подтвердите пароль" styleClass="form-label-new"/>
                <PasswordField fx:id="confirmField" promptText="Повторите пароль" styleClass="input-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="form-error" visible="false"
                   wrapText="true" maxWidth="340"/>

            <Button fx:id="registerButton" text="Создать аккаунт" styleClass="btn-primary-lg"
                    onAction="#handleRegister" prefWidth="340"/>
            <Button text="← Назад ко входу" styleClass="link-btn" onAction="#handleBack"/>
        </VBox>
    </HBox>
</StackPane>
