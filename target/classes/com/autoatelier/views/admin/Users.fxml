<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      prefWidth="1200" prefHeight="800"
      fx:controller="com.autoatelier.controller.admin.AdminUsersController"
      styleClass="app-root" spacing="0">

    <HBox styleClass="topbar-header topbar-admin" alignment="CENTER_LEFT" spacing="12">
        <Label text="🚗 Ателье Автомобилей" styleClass="topbar-logo"/>
        <Label text="Администратор" styleClass="topbar-role-badge topbar-role-admin"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userNameLabel" styleClass="topbar-username" visible="false" managed="false"/>
        <Button text="Выйти" styleClass="topbar-logout-btn" onAction="#handleLogout"/>
    </HBox>

    <HBox styleClass="topbar-nav" spacing="0">
        <Button text="Пользователи" styleClass="nav-tab nav-tab-active" onAction="#goToUsers"/>
        <Button text="Услуги"       styleClass="nav-tab"                onAction="#goToServices"/>
        <Button text="Статистика"   styleClass="nav-tab"                onAction="#goToStats"/>
        <Button text="Архив"        styleClass="nav-tab"                onAction="#goToArchive"/>
        <Button text="Профиль"      styleClass="nav-tab"                onAction="#goToProfile"/>
    </HBox>

    <VBox styleClass="page-content" spacing="18" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Пользователи" styleClass="page-title"/>
                <Label text="ПКМ по строке — изменить роль или заблокировать пользователя." styleClass="page-subtitle"/>
            </VBox>
            <Button text="Обновить" styleClass="btn-outline" onAction="#refresh"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍  Поиск по имени или email..."
                       styleClass="search-field" prefWidth="320"/>
            <ComboBox fx:id="roleFilter" prefWidth="180" styleClass="filter-combo"/>
        </HBox>

        <Label fx:id="statusLabel" styleClass="page-subtitle"/>

        <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <columns>
                <TableColumn fx:id="colName"  text="Имя"              prefWidth="200"/>
                <TableColumn fx:id="colEmail" text="Email"            prefWidth="230"/>
                <TableColumn fx:id="colPhone" text="Телефон"          prefWidth="150"/>
                <TableColumn fx:id="colRole"  text="Роль"             prefWidth="130"/>
                <TableColumn fx:id="colStatus" text="Статус"           prefWidth="140"/>
                <TableColumn fx:id="colDate"  text="Дата регистрации" prefWidth="140"/>
            </columns>
            <placeholder><Label text="Пользователи не найдены" styleClass="page-subtitle"/></placeholder>
        </TableView>
    </VBox>
</VBox>
