<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="800" prefWidth="1200"
           styleClass="auth-v2-root"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17.0.12"
           fx:controller="com.autoatelier.controller.LoginController">

    <Region styleClass="auth-v2-bg"/>

    <Circle radius="280" styleClass="auth-v2-circle-lg"
             translateX="-400" translateY="-200"/>
    <Circle radius="180" styleClass="auth-v2-circle-sm"
             translateX="450" translateY="280"/>

    <HBox alignment="CENTER" maxWidth="960" maxHeight="620"
          styleClass="auth-v2-card">

        <VBox styleClass="auth-v2-brand" alignment="CENTER" spacing="24" minWidth="380" maxWidth="380">
            <Label text="🚗" styleClass="auth-v2-brand-icon"/>
            <VBox spacing="10" alignment="CENTER">
                <Label text="Ателье" styleClass="auth-v2-brand-title-line1"/>
                <Label text="Автомобилей" styleClass="auth-v2-brand-title-line2"/>
            </VBox>
            <Label text="Профессиональный тюнинг и кастомизация премиум-класса"
                   styleClass="auth-v2-brand-sub" wrapText="true" textAlignment="CENTER"
                   maxWidth="300"/>
            <VBox spacing="14" maxWidth="300">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="⚡" styleClass="auth-v2-feature-icon"/>
                    <Label text="Быстрое оформление заявок" styleClass="auth-v2-feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="🔒" styleClass="auth-v2-feature-icon"/>
                    <Label text="Безопасное хранение данных" styleClass="auth-v2-feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="📊" styleClass="auth-v2-feature-icon"/>
                    <Label text="Аналитика и управление заказами" styleClass="auth-v2-feature-text"/>
                </HBox>
            </VBox>
        </VBox>

        <Region styleClass="auth-v2-divider" minWidth="1" maxWidth="1" minHeight="400"/>

        <VBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS" styleClass="auth-v2-form-panel">
            <VBox alignment="CENTER" spacing="28" maxWidth="360">

                <VBox spacing="6" alignment="CENTER_LEFT">
                    <Label text="Добро пожаловать" styleClass="auth-v2-form-title"/>
                    <Label text="Войдите в свой аккаунт, чтобы продолжить"
                           styleClass="auth-v2-form-sub" wrapText="true"/>
                </VBox>

                <VBox spacing="18" maxWidth="360">
                    <VBox spacing="7">
                        <Label text="Email" styleClass="auth-v2-label"/>
                        <TextField fx:id="emailField" promptText="your@email.com"
                                   styleClass="auth-v2-input"/>
                    </VBox>
                    <VBox spacing="7">
                        <Label text="Пароль" styleClass="auth-v2-label"/>
                        <PasswordField fx:id="passwordField" promptText="••••••••"
                                       styleClass="auth-v2-input"/>
                    </VBox>
                </VBox>

                <Label fx:id="errorLabel" styleClass="auth-v2-error"
                       visible="false" managed="false"
                       wrapText="true" maxWidth="360"/>

                <VBox spacing="14" maxWidth="360">
                    <Button fx:id="loginButton" text="Войти →"
                            styleClass="auth-v2-btn-primary"
                            onAction="#handleLogin"
                            maxWidth="Infinity"/>
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Нет аккаунта?" styleClass="auth-v2-hint"/>
                        <Button text="Зарегистрироваться"
                                styleClass="auth-v2-link-btn"
                                onAction="#handleRegister"/>
                    </HBox>
                </VBox>

                <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <ProgressIndicator styleClass="loader" prefWidth="36" prefHeight="36"/>
                    <Label text="Выполняется вход..." styleClass="auth-v2-hint"/>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
