<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      prefWidth="1200" prefHeight="800"
      fx:controller="com.autoatelier.controller.client.ClientDashboardController"
      styleClass="app-root" spacing="0">

    <HBox styleClass="topbar-header" alignment="CENTER_LEFT">
        <Label text="🚗 Ателье Автомобилей" styleClass="topbar-logo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userNameLabel" styleClass="topbar-username" visible="false" managed="false"/>
        <Button text="Выйти" styleClass="topbar-logout-btn" onAction="#handleLogout"/>
    </HBox>

    <HBox styleClass="topbar-nav" spacing="0">
        <Button text="Главная"      styleClass="nav-tab nav-tab-active" onAction="#goToDashboard"/>
        <Button text="Каталог"      styleClass="nav-tab"                onAction="#goToCatalog"/>
        <Button text="Новая заявка" styleClass="nav-tab"                onAction="#goToNewOrder"/>
        <Button text="Мои заказы"   styleClass="nav-tab"                onAction="#goToOrders"/>
        <Button text="Профиль"      styleClass="nav-tab"                onAction="#goToProfile"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <VBox styleClass="page-content" spacing="28">

            <VBox spacing="4">
                <Label fx:id="greetingLabel" styleClass="page-title"/>
                <Label text="Добро пожаловать в ателье. Выберите услугу и оформите заявку." styleClass="page-subtitle"/>
            </VBox>

            
            <HBox spacing="16">
                <VBox styleClass="stat-card-new stat-accent-blue" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="📋  Всего заявок" styleClass="stat-card-label"/>
                    <Label fx:id="totalOrdersLabel" text="—" styleClass="stat-card-value"/>
                </VBox>
                <VBox styleClass="stat-card-new stat-accent-amber" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="⚙️  В работе" styleClass="stat-card-label"/>
                    <Label fx:id="activeOrdersLabel" text="—" styleClass="stat-card-value"/>
                </VBox>
                <VBox styleClass="stat-card-new stat-accent-green" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="✅  Завершено" styleClass="stat-card-label"/>
                    <Label fx:id="completedOrdersLabel" text="—" styleClass="stat-card-value"/>
                </VBox>
            </HBox>

            
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Последние заявки" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                    <Button text="Все заявки →" styleClass="link-btn" onAction="#goToOrders"/>
                </HBox>
                <VBox fx:id="recentOrdersBox" spacing="10"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
