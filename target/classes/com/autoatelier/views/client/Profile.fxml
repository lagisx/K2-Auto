<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      prefWidth="1200" prefHeight="800"
      fx:controller="com.autoatelier.controller.client.ClientProfileController"
      styleClass="app-root" spacing="0">

    <HBox styleClass="topbar-header" alignment="CENTER_LEFT">
        <Label text="🚗 Ателье Автомобилей" styleClass="topbar-logo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="userNameLabel" styleClass="topbar-username" visible="false" managed="false"/>
        <Button text="Выйти" styleClass="topbar-logout-btn" onAction="#handleLogout"/>
    </HBox>

    <HBox styleClass="topbar-nav" spacing="0">
        <Button text="Каталог"      styleClass="nav-tab"                onAction="#goToCatalog"/>
        <Button text="Новая заявка" styleClass="nav-tab"                onAction="#goToNewOrder"/>
        <Button text="Мои заказы"   styleClass="nav-tab"                onAction="#goToOrders"/>
        <Button text="История оплат" styleClass="nav-tab"                onAction="#goToPayHistory"/>
        <Button text="Профиль"      styleClass="nav-tab nav-tab-active" onAction="#goToProfile"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
        <VBox styleClass="page-content" spacing="24">

            <VBox spacing="4">
                <Label text="Профиль" styleClass="page-title"/>
                <Label fx:id="emailLabel" styleClass="profile-email"/>
            </VBox>

            <VBox styleClass="profile-section" spacing="16">
                <Label text="Личные данные" styleClass="profile-section-title"/>
                <Separator styleClass="detail-sep"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="ИМЯ И ФАМИЛИЯ" styleClass="form-label-new"/>
                        <TextField fx:id="nameField" promptText="Иван Иванов" styleClass="input-field"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="ТЕЛЕФОН" styleClass="form-label-new"/>
                        <TextField fx:id="phoneField" promptText="+7 (999) 000-00-00" styleClass="input-field"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Button text="Сохранить изменения" styleClass="btn-primary-sm" onAction="#handleSaveProfile"/>
                    <Label fx:id="profileStatus" styleClass="status-hint"/>
                </HBox>
            </VBox>

            <VBox styleClass="profile-section" spacing="16">
                <Label text="Безопасность" styleClass="profile-section-title"/>
                <Separator styleClass="detail-sep"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="НОВЫЙ ПАРОЛЬ" styleClass="form-label-new"/>
                        <PasswordField fx:id="newPasswordField" promptText="Минимум 6 символов" styleClass="input-field"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="ПОДТВЕРДИТЕ ПАРОЛЬ" styleClass="form-label-new"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Повторите пароль" styleClass="input-field"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Button text="Изменить пароль" styleClass="btn-outline" onAction="#handleChangePassword"/>
                    <Label fx:id="passwordStatus" styleClass="status-hint"/>
                </HBox>
            </VBox>

            <VBox styleClass="profile-section" spacing="16">
                <Label text="Карты оплаты" styleClass="profile-section-title"/>
                <Separator styleClass="detail-sep"/>

                <VBox fx:id="cardsListBox" spacing="10"/>

                <Separator styleClass="detail-sep"/>
                <Label text="Добавить карту" styleClass="profile-subsection-title"/>

                <VBox spacing="12" styleClass="card-add-form">
                    <VBox spacing="6">
                        <Label text="НОМЕР КАРТЫ" styleClass="form-label-new"/>
                        <TextField fx:id="cardNumberField" promptText="0000 0000 0000 0000"
                                   styleClass="input-field card-number-field"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="ИМЯ ДЕРЖАТЕЛЯ (латиницей)" styleClass="form-label-new"/>
                        <TextField fx:id="cardHolderField" promptText="IVAN IVANOV" styleClass="input-field"/>
                    </VBox>
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="МЕСЯЦ" styleClass="form-label-new"/>
                            <TextField fx:id="expiryMonthField" promptText="MM" styleClass="input-field" maxWidth="100"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="ГОД" styleClass="form-label-new"/>
                            <TextField fx:id="expiryYearField" promptText="YY" styleClass="input-field" maxWidth="100"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="CVV" styleClass="form-label-new"/>
                            <PasswordField promptText="•••" styleClass="input-field" maxWidth="100"
                                           disable="true">
                                <tooltip><Tooltip text="CVV не сохраняется — мы его не храним"/></tooltip>
                            </PasswordField>
                        </VBox>
                    </HBox>
                    <Label text="🔒 CVV-код не сохраняется. Хранятся только последние 4 цифры номера."
                           styleClass="security-hint"/>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button text="Добавить карту" styleClass="btn-primary-sm" onAction="#handleAddCard"/>
                        <Label fx:id="cardStatus" styleClass="status-hint"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox styleClass="profile-section profile-danger-section" spacing="14">
                <Label text="Опасная зона" styleClass="profile-section-title profile-danger-title"/>
                <Separator styleClass="detail-sep"/>
                <Label text="Удаление аккаунта необратимо. Все ваши заказы и данные будут удалены."
                       styleClass="page-subtitle" wrapText="true"/>
                <Button text="Удалить аккаунт" styleClass="btn-delete-account"
                        onAction="#handleDeleteAccount"/>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>
