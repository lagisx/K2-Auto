<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefWidth="1200" prefHeight="800"
           styleClass="auth-v2-root"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.autoatelier.controller.RegisterController">

    <Region styleClass="auth-v2-bg"/>

    <Circle radius="280" styleClass="auth-v2-circle-lg"
             translateX="400" translateY="-220"/>
    <Circle radius="160" styleClass="auth-v2-circle-sm"
             translateX="-420" translateY="260"/>

    <HBox alignment="CENTER" maxWidth="980" maxHeight="700"
          styleClass="auth-v2-card">

        <VBox styleClass="auth-v2-brand" alignment="CENTER" spacing="24" minWidth="360" maxWidth="360">
            <Label text="🚗" styleClass="auth-v2-brand-icon"/>
            <VBox spacing="10" alignment="CENTER">
                <Label text="Создайте" styleClass="auth-v2-brand-title-line1"/>
                <Label text="аккаунт" styleClass="auth-v2-brand-title-line2"/>
            </VBox>
            <Label text="Начните пользоваться сервисом уже сегодня"
                   styleClass="auth-v2-brand-sub" wrapText="true" textAlignment="CENTER"
                   maxWidth="280"/>
            <VBox spacing="14" maxWidth="280">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="✅" styleClass="auth-v2-feature-icon"/>
                    <Label text="Отслеживайте статус заявок" styleClass="auth-v2-feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="🔧" styleClass="auth-v2-feature-icon"/>
                    <Label text="Выбирайте услуги из каталога" styleClass="auth-v2-feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="💳" styleClass="auth-v2-feature-icon"/>
                    <Label text="Управляйте платёжными картами" styleClass="auth-v2-feature-text"/>
                </HBox>
            </VBox>
        </VBox>

        <Region styleClass="auth-v2-divider" minWidth="1" maxWidth="1" minHeight="420"/>

        <VBox alignment="CENTER" spacing="0" HBox.hgrow="ALWAYS" styleClass="auth-v2-form-panel">
            <VBox alignment="CENTER_LEFT" spacing="24" maxWidth="360">

                <VBox spacing="6">
                    <Label text="Регистрация" styleClass="auth-v2-form-title"/>
                    <Label text="Заполните данные для создания аккаунта"
                           styleClass="auth-v2-form-sub" wrapText="true"/>
                </VBox>

                <VBox spacing="14" maxWidth="360">
                    <VBox spacing="7">
                        <Label text="Имя и фамилия" styleClass="auth-v2-label"/>
                        <TextField fx:id="nameField" promptText="Иван Иванов"
                                   styleClass="auth-v2-input"/>
                    </VBox>
                    <VBox spacing="7">
                        <Label text="Телефон" styleClass="auth-v2-label"/>
                        <TextField fx:id="phoneField" promptText="+7 (999) 000-00-00"
                                   styleClass="auth-v2-input"/>
                    </VBox>
                    <VBox spacing="7">
                        <Label text="Email" styleClass="auth-v2-label"/>
                        <TextField fx:id="emailField" promptText="your@email.com"
                                   styleClass="auth-v2-input"/>
                    </VBox>
                    <VBox spacing="7">
                        <Label text="Пароль" styleClass="auth-v2-label"/>
                        <PasswordField fx:id="passwordField" promptText="Минимум 6 символов"
                                       styleClass="auth-v2-input"/>
                    </VBox>
                </VBox>

                <Label fx:id="errorLabel" styleClass="auth-v2-error"
                       visible="false" managed="false"
                       wrapText="true" maxWidth="360"/>

                <VBox spacing="14" maxWidth="360">
                    <Button fx:id="registerButton" text="Создать аккаунт →"
                            styleClass="auth-v2-btn-primary"
                            onAction="#handleRegister"
                            maxWidth="Infinity"/>
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Уже есть аккаунт?" styleClass="auth-v2-hint"/>
                        <Button text="Войти" styleClass="auth-v2-link-btn" onAction="#handleBack"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
