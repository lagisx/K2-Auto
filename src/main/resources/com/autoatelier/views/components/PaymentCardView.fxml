<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      styleClass="payment-card-visual"
      maxWidth="340" minWidth="280" spacing="0">

    <HBox alignment="CENTER_LEFT" spacing="0">
        <Label fx:id="chipLabel" text="💳" styleClass="payment-card-chip"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="networkLabel" text="VISA" styleClass="payment-card-network"/>
        <Button fx:id="deleteBtn" text="✕" styleClass="btn-delete-card"/>
    </HBox>

    <Label fx:id="numberLabel" text="**** **** **** 0000"
           styleClass="payment-card-number-visual"
           style="-fx-padding: 12 0 8 0;"/>

    <HBox alignment="BOTTOM_LEFT" spacing="0">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="ДЕРЖАТЕЛЬ" styleClass="payment-card-label-small"/>
            <Label fx:id="holderLabel" text="IVAN IVANOV"
                   styleClass="payment-card-holder-visual"/>
        </VBox>
        <VBox spacing="3" alignment="TOP_RIGHT">
            <Label text="ДЕЙСТВУЕТ ДО" styleClass="payment-card-label-small"/>
            <Label fx:id="expiryLabel" text="12 / 27"
                   styleClass="payment-card-expiry-visual"/>
        </VBox>
    </HBox>
</VBox>
